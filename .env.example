# Streambert web port — copy to `.env` (same folder as docker-compose.yml) and
# fill in. `.env` is git-ignored and must never be committed.
#
#   cp .env.example .env
#   docker compose up -d --build

# --- Required ---------------------------------------------------------------
# Login password for the single-user web app.
STREAMBERT_PASSWORD=choose-a-strong-password
# Secret that signs the session cookie. Generate with: openssl rand -hex 32
STREAMBERT_COOKIE_SECRET=paste-output-of-openssl-rand-hex-32
# Caddy site address (public domain, or LAN host/IP when using `tls internal`).
DOMAIN=streambert.example.com

# --- Optional ---------------------------------------------------------------
# TMDB Read Access Token (the long "eyJ..." JWT). Set it here to skip the in-app
# setup screen — you'll never re-enter it on start. You can still enter/override
# it in the app; a token saved there takes precedence. See tmdb-tutorial.md.
STREAMBERT_TMDB_TOKEN=

# ACME email for Let's Encrypt expiry notices (public-domain mode only).
TLS_EMAIL=
# Override only if you mount the downloader binary somewhere non-default.
# STREAMBERT_DOWNLOADER=/usr/local/bin/vid-dl

# First-run admin bootstrap (used ONLY when the user database is empty).
# If unset, an "admin" user is created with STREAMBERT_PASSWORD as its password.
STREAMBERT_ADMIN_USER=admin
STREAMBERT_ADMIN_PASSWORD=
